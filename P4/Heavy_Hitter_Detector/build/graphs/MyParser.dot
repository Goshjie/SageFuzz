digraph MyParser{
start [shape=rectangle,label="start
(hdr.ethernet.etherType)"]
ipv4 [shape=rectangle,label="ipv4
(hdr.ipv4.protocol)"]
tcp [shape=rectangle,label="tcp"]
accept [shape=rectangle,label="accept"]
reject [shape=rectangle,label="reject"]
start -> ipv4 [label="16w0x800"]
start -> accept [label="default"]
ipv4 -> tcp [label="8w6"]
ipv4 -> accept [label="default"]
tcp -> accept [label="always"]
}
